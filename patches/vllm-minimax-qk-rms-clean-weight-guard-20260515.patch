+            )
+            == "1"
+        )
+        if not restore_weight:
+            return norm.weight
+        clean_weight_xpu = getattr(
+            norm,
+            "_minimax_clean_weight_xpu",
+            getattr(norm.weight, "_minimax_clean_weight_xpu", None),
+        )
+        if torch.compiler.is_compiling():
+            return clean_weight_xpu if clean_weight_xpu is not None else norm.weight
+        if norm.weight.is_xpu and torch.xpu.is_current_stream_capturing():
+            return clean_weight_xpu if clean_weight_xpu is not None else norm.weight
+        min_tokens = int(
