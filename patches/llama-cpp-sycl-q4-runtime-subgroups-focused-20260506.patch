+            break;
+        case 8:
+            reorder_mul_mat_vec_q4_0_q8_1_sycl_t<8>(vx, vy, dst, ncols, nrows, stream);
+            break;
+        case 16:
+            reorder_mul_mat_vec_q4_0_q8_1_sycl_t<16>(vx, vy, dst, ncols, nrows, stream);
