@@ -80,6 +80,53 @@ def _minimax_qk_norm_xpu_helper_enabled() -> bool:
     return os.environ.get("VLLM_MINIMAX_QK_NORM_XPU_DIRECT", "0") == "1"
 
 
+def _minimax_post_attn_ar_fused_enabled() -> bool:
+    return os.environ.get("VLLM_MINIMAX_POST_ATTN_AR_FUSED_RMS_XPU", "0") == "1"
+
+
+_MINIMAX_POST_ATTN_AR_FUSED_REGISTERED = False
+
+
+def _ensure_minimax_post_attn_ar_fused_op() -> None:
+    global _MINIMAX_POST_ATTN_AR_FUSED_REGISTERED
+    if _MINIMAX_POST_ATTN_AR_FUSED_REGISTERED:
+        return
+
+    import torch.distributed as dist
+
+    from vllm.distributed.parallel_state import get_tp_group
+    from vllm.utils.torch_utils import direct_register_custom_op
+
+    def _post_attn_ar_fused_rms(
+        input_: torch.Tensor,
+        residual: torch.Tensor,
+        weight: torch.Tensor,
+        epsilon: float,
+    ) -> tuple[torch.Tensor, torch.Tensor]:
+        output = input_.clone()
+        dist.all_reduce(output, group=get_tp_group().device_group)
+        residual_out = residual.clone()
+        torch.ops._C.fused_add_rms_norm(output, residual_out, weight, epsilon)
+        return output, residual_out
+
+    def _post_attn_ar_fused_rms_fake(
+        input_: torch.Tensor,
+        residual: torch.Tensor,
+        weight: torch.Tensor,
+        epsilon: float,
+    ) -> tuple[torch.Tensor, torch.Tensor]:
+        return torch.empty_like(input_), torch.empty_like(residual)
+
+    direct_register_custom_op(
+        op_name="minimax_post_attn_ar_fused_rms",
+        op_func=_post_attn_ar_fused_rms,
+        fake_impl=_post_attn_ar_fused_rms_fake,
+        mutates_args=[],
+    )
+    _MINIMAX_POST_ATTN_AR_FUSED_REGISTERED = True
+
+
 def _minimax_qk_norm_xpu_helper(
