+                ggml_nelements(outputs[i]) != ne ||
+                ggml_nbytes(partials[i]) != nbytes || ggml_nbytes(residuals[i]) != nbytes ||
+                ggml_nbytes(outputs[i]) != nbytes ||
+                !ggml_is_contiguously_allocated(partials[i]) ||
+                !ggml_is_contiguously_allocated(residuals[i]) ||
