+        ggml_backend_buffer_t residual_buf = residuals[i]->view_src ? residuals[i]->view_src->buffer : residuals[i]->buffer;
+        ggml_backend_buffer_t output_buf = outputs[i]->view_src ? outputs[i]->view_src->buffer : outputs[i]->buffer;
+        if (!ggml_backend_buffer_is_sycl(partial_buf) ||
+                !ggml_backend_buffer_is_sycl(residual_buf) ||
+                !ggml_backend_buffer_is_sycl(output_buf)) {
+            return false;
+        }
+
+        ggml_backend_sycl_context * sycl_ctx = (ggml_backend_sycl_context *) comm_ctx->backends[i]->context;
+        ggml_backend_sycl_buffer_context * partial_ctx = (ggml_backend_sycl_buffer_context *) partial_buf->context;
+        ggml_backend_sycl_buffer_context * residual_ctx = (ggml_backend_sycl_buffer_context *) residual_buf->context;
+        ggml_backend_sycl_buffer_context * output_ctx = (ggml_backend_sycl_buffer_context *) output_buf->context;
+        if (sycl_ctx->device != partial_ctx->device ||
