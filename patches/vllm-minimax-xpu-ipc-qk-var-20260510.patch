+                "MiniMax Q/K XPU IPC allreduce initialized "
+                "(world_size=%d, slots=%d, max_tokens=%d)",
+                self.world_size,
+                _MINIMAX_QK_RMS_XPU_IPC_SLOTS,
+                _MINIMAX_QK_RMS_XPU_IPC_MAX_TOKENS,
+            )
+        return True
+
+    def allreduce_average(self, qk_var: torch.Tensor, slot: int) -> bool:
+        if qk_var.size(0) > _MINIMAX_QK_RMS_XPU_IPC_MAX_TOKENS:
+            return False
+        if slot < 0 or slot >= _MINIMAX_QK_RMS_XPU_IPC_SLOTS:
+            return False
+        if not self.initialized:
+            if torch.compiler.is_compiling():
+                return False
+            if not self.ensure_initialized(qk_var):
+                return False
+        assert self.payload_ptrs is not None
+        assert self.seq_ptrs is not None
+        assert self.counter is not None
+        ipc_op = (
+            torch.ops.minimax_qk_rms_xpu_ipc.allreduce_qk_var_seq_scalar
+            if _MINIMAX_QK_RMS_XPU_IPC_SCALAR_SEQ
+            else torch.ops.minimax_qk_rms_xpu_ipc.allreduce_qk_var_seq_counter
+        )
+        ipc_op(
+            qk_var,
+            self.payload_ptrs,
+            self.seq_ptrs,
+            self.counter,
+            slot,
+            _MINIMAX_QK_RMS_XPU_IPC_MAX_TOKENS,
+            self.world_size,
+            _MINIMAX_QK_RMS_XPU_IPC_TIMEOUT_ITERS,
+        )
+        return True
+
