+                _MINIMAX_QK_RMS_XPU_IPC_SLOTS,
+                _MINIMAX_QK_RMS_XPU_IPC_MAX_TOKENS,
+                2,
+            ),
+            device=device,
+            dtype=torch.int32,
+        )
+        counter = torch.zeros(
+            (_MINIMAX_QK_RMS_XPU_IPC_SLOTS,), device=device, dtype=torch.int32
+        )
+
+        payload_handle = _minimax_qk_rms_xpu_ipc.get_ipc_handle(mailbox)
+        seq_handle = _minimax_qk_rms_xpu_ipc.get_ipc_handle(seq_mailbox)
+        payload_handles = [None for _ in range(self.world_size)]
+        seq_handles = [None for _ in range(self.world_size)]
+        dist.all_gather_object(
+            payload_handles, payload_handle, group=tp_group.cpu_group
+        )
+        dist.all_gather_object(seq_handles, seq_handle, group=tp_group.cpu_group)
+
+        payload_ptrs_host: list[int] = []
+        seq_ptrs_host: list[int] = []
+        for peer_rank, handle in enumerate(payload_handles):
+            if peer_rank == tp_group.rank_in_group:
+                payload_ptrs_host.append(mailbox.data_ptr())
+            else:
+                payload_ptrs_host.append(
+                    _minimax_qk_rms_xpu_ipc.open_ipc_handle(
+                        handle, local_device_index
+                    )
+                )
+        for peer_rank, handle in enumerate(seq_handles):
+            if peer_rank == tp_group.rank_in_group:
+                seq_ptrs_host.append(seq_mailbox.data_ptr())
+            else:
+                seq_ptrs_host.append(
+                    _minimax_qk_rms_xpu_ipc.open_ipc_handle(
+                        handle, local_device_index
+                    )
+                )
+
+        ordered_payload_ptrs = [mailbox.data_ptr()] + [
+            payload_ptrs_host[i]
+            for i in range(self.world_size)
+            if i != tp_group.rank_in_group
+        ]
+        ordered_seq_ptrs = [seq_mailbox.data_ptr()] + [
+            seq_ptrs_host[i]
+            for i in range(self.world_size)
+            if i != tp_group.rank_in_group
+        ]
+        self.payload_ptrs = torch.tensor(
+            [_signed_ipc_ptr(ptr) for ptr in ordered_payload_ptrs],
+            device=device,
+            dtype=torch.int64,
+        )
+        self.seq_ptrs = torch.tensor(
+            [_signed_ipc_ptr(ptr) for ptr in ordered_seq_ptrs],
+            device=device,
+            dtype=torch.int64,
+        )
+        self.counter = counter
+        self.mailbox = mailbox
+        self.seq_mailbox = seq_mailbox
+        self.initialized = True
+        if tp_group.rank_in_group == 0:
