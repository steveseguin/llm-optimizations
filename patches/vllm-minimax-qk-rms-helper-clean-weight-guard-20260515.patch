+    def _router_choice_scores(self, router_logits: torch.Tensor) -> torch.Tensor:
+        scoring_func = getattr(self.experts, "scoring_func", "softmax")
+        if scoring_func == "sigmoid":
+            scores = router_logits.sigmoid()
+        elif scoring_func == "softmax":
+            scores = router_logits.softmax(dim=-1)
+        elif scoring_func == "sqrtsoftplus":
+            scores = torch.nn.functional.softplus(router_logits).sqrt()
+        else:
+            scores = router_logits
+        if self.e_score_correction_bias is not None:
+            scores = scores + self.e_score_correction_bias.to(
+                scores.dtype
+            ).unsqueeze(0)
+        return scores
+
+    def _candidate_router_topk(
+        self, hidden_states: torch.Tensor, candidate_count: int
+    ) -> tuple[torch.Tensor, torch.Tensor, torch.Tensor]:
+        top_k = int(getattr(self.experts, "top_k", 8))
+        candidate_count = max(top_k, candidate_count)
+        gate_weight_fp32 = getattr(self.gate, "weight", None)
+        if gate_weight_fp32 is None:
+            raise RuntimeError("MiniMax candidate router requires gate.weight")
+        if getattr(self.experts, "scoring_func", "softmax") != "sigmoid":
+            raise RuntimeError("MiniMax candidate router currently expects sigmoid routing")
+        if self.e_score_correction_bias is None:
+            raise RuntimeError("MiniMax candidate router expects correction bias")
+
+        router_logits_fp16 = torch.nn.functional.linear(
+            hidden_states.to(torch.float16), self._gate_weight_fp16
+        ).to(torch.float32)
+        choice_scores_fp16 = self._router_choice_scores(router_logits_fp16)
+        _, candidate_ids = torch.topk(
+            choice_scores_fp16, k=candidate_count, dim=-1
+        )
+
+        repair_topk = _get_minimax_m2_candidate_repair_topk()
+        if repair_topk is not None and hidden_states.device.type == "xpu":
+            topk_weights, topk_ids = repair_topk(
+                hidden_states,
+                candidate_ids,
+                gate_weight_fp32,
+                self.e_score_correction_bias,
+                top_k,
+                getattr(self.experts, "renormalize", True),
+            )
+            return topk_weights.contiguous(), topk_ids.contiguous(), router_logits_fp16
+
+        candidate_weights = gate_weight_fp32[candidate_ids.long()]
+        exact_logits = (
+            candidate_weights * hidden_states.to(torch.float32).unsqueeze(1)
+        ).sum(dim=-1)
+        exact_scores = exact_logits.sigmoid()
+        exact_choice_scores = exact_scores + self.e_score_correction_bias[
+            candidate_ids.long()
+        ].to(exact_scores.dtype)
+        _, local_topk = torch.topk(exact_choice_scores, k=top_k, dim=-1)
+        topk_ids = candidate_ids.gather(1, local_topk).to(torch.int32)
+        topk_weights = exact_scores.gather(1, local_topk).to(torch.float32)
+        if getattr(self.experts, "renormalize", True):
+            topk_weights = topk_weights / topk_weights.sum(dim=-1, keepdim=True)
+        return topk_weights.contiguous(), topk_ids.contiguous(), router_logits_fp16
+
