+static size_t get_backend_reg_dev_index(ggml_backend_dev_t dev) {
+    ggml_backend_reg_t reg = ggml_backend_dev_backend_reg(dev);
+    for (size_t i = 0; i < ggml_backend_reg_dev_count(reg); ++i) {
+        if (ggml_backend_reg_dev_get(reg, i) == dev) {
+            return i;
+        }
+    }
+    throw std::runtime_error(format("device %s not found in its backend reg", ggml_backend_dev_name(dev)));
+}
+
+static std::vector<float> make_backend_reg_tensor_split(
+        ggml_backend_reg_t reg,
+        const std::vector<llama_device> & devices,
+        const float * tensor_split) {
+    // Backend split-buffer APIs use physical backend-registry indices, while
+    // llama.cpp's tensor_split is indexed by the model's selected device list.
+    // Keep the array large enough for backends that read up to their max device
+    // count (SYCL currently reads GGML_SYCL_MAX_DEVICES entries).
+    constexpr size_t max_backend_split_devices = 128;
+    std::vector<float> active_tensor_split(max_backend_split_devices, 0.0f);
+
+    const bool all_zero = tensor_split == nullptr ||
+        std::all_of(tensor_split, tensor_split + devices.size(), [](float x) { return x == 0.0f; });
+
+    for (size_t i = 0; i < devices.size(); ++i) {
+        if (devices[i].is_meta || ggml_backend_dev_backend_reg(devices[i].dev) != reg) {
+            continue;
+        }
+
+        const size_t reg_index = get_backend_reg_dev_index(devices[i].dev);
+        if (reg_index >= active_tensor_split.size()) {
+            throw std::runtime_error(format(
+                "%s: backend device index %zu exceeds split array size %zu",
+                __func__, reg_index, active_tensor_split.size()));
+        }
+
+        if (all_zero) {
+            size_t free = 0;
+            size_t total = 0;
+            ggml_backend_dev_memory(devices[i].dev, &free, &total);
+            active_tensor_split[reg_index] = free > 0 ? (float) free : 1.0f;
+        } else {
+            active_tensor_split[reg_index] = tensor_split[i];
+        }
+    }
+
+    return active_tensor_split;
+}
