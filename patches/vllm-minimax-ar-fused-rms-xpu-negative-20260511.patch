+def _get_minimax_ar_fused_add_rms_op():
+    global _MINIMAX_AR_FUSED_ADD_RMS_OP, _MINIMAX_AR_FUSED_ADD_RMS_TRIED
+    if not _minimax_ar_fused_add_rms_xpu_enabled():
+        return None
+    if _MINIMAX_AR_FUSED_ADD_RMS_TRIED:
+        return _MINIMAX_AR_FUSED_ADD_RMS_OP
+    _MINIMAX_AR_FUSED_ADD_RMS_TRIED = True
+    try:
+        import minimax_ar_fused_rms_xpu  # noqa: F401
+
+        if (
+            hasattr(torch.ops, "minimax_ar_fused_rms_xpu")
+            and hasattr(torch.ops.minimax_ar_fused_rms_xpu, "ar_fused_add_rms")
+        ):
+            _MINIMAX_AR_FUSED_ADD_RMS_OP = (
+                torch.ops.minimax_ar_fused_rms_xpu.ar_fused_add_rms.default
+            )
+    except Exception:
+        _MINIMAX_AR_FUSED_ADD_RMS_OP = None
+    return _MINIMAX_AR_FUSED_ADD_RMS_OP
