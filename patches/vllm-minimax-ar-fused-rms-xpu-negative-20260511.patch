+def _minimax_qk_norm_xpu_helper(
+    qkv: torch.Tensor,
+    q_norm: MiniMaxText01RMSNormTP,
+    k_norm: MiniMaxText01RMSNormTP,
+    q_size: int,
+    kv_size: int,
+) -> tuple[torch.Tensor, torch.Tensor]:
+    import minimax_qk_rms_xpu  # noqa: F401
+
+    qkv = qkv.contiguous()
+    qk_var = torch.empty((qkv.shape[0], 2), dtype=torch.float32, device=qkv.device)
+    torch.ops.minimax_qk_rms_xpu.var(qkv, qk_var, q_size, kv_size)
+    if q_norm.tp_world > 1:
+        qk_var = tensor_model_parallel_all_reduce(qk_var) / q_norm.tp_world
+    q = torch.empty((qkv.shape[0], q_size), dtype=qkv.dtype, device=qkv.device)
+    k = torch.empty((qkv.shape[0], kv_size), dtype=qkv.dtype, device=qkv.device)
+    torch.ops.minimax_qk_rms_xpu.apply(
+        qkv,
+        qk_var,
+        q_norm.weight,
+        k_norm.weight,
+        q,
+        k,
+        q_size,
+        kv_size,
+        q_norm.variance_epsilon,
+    )
+    return q, k
+
