+def prune_xpu_search_space(num_tokens, search_space, topk):
+    # MiniMax single-request decode reaches the MoE kernel as a very small
+    # routed-token GEMM. Large BLOCK_SIZE_M/GROUP_SIZE_M candidates compile and
+    # run, but make the search take hours while being poor fits for M=1 decode.
+    m_routed = num_tokens * topk
+    pruned_configs = []
+    for config in search_space:
+        block_m = config["BLOCK_SIZE_M"]
+        group_m = config["GROUP_SIZE_M"]
+        if m_routed * 2 < block_m and block_m != 16:
+            continue
+        if group_m * block_m > m_routed and group_m != 1:
+            continue
+        pruned_configs.append(config)
+    return pruned_configs
+
