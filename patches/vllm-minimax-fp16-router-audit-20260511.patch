+    def _router_choice_scores(self, router_logits: torch.Tensor) -> torch.Tensor:
+        scoring_func = getattr(self.experts, "scoring_func", "softmax")
+        if scoring_func == "sigmoid":
+            scores = router_logits.sigmoid()
+        elif scoring_func == "softmax":
+            scores = router_logits.softmax(dim=-1)
+        elif scoring_func == "sqrtsoftplus":
+            scores = torch.nn.functional.softplus(router_logits).sqrt()
+        else:
+            scores = router_logits
+        if self.e_score_correction_bias is not None:
+            scores = scores + self.e_score_correction_bias.to(
+                scores.dtype
+            ).unsqueeze(0)
+        return scores
