+    def _audit_fp16_router(
+        self,
+        router_logits_fp32: torch.Tensor,
+        router_logits_fp16: torch.Tensor,
+        num_tokens: int,
+    ) -> None:
+        audit_key = "decode" if num_tokens == 1 else "prefill"
+        if audit_key in self._fp16_router_audit_printed:
+            return
+        self._fp16_router_audit_printed.add(audit_key)
+
+        top_k = int(getattr(self.experts, "top_k", 8))
+        with torch.no_grad():
+            fp32_choice_scores = self._router_choice_scores(router_logits_fp32)
+            fp16_choice_scores = self._router_choice_scores(router_logits_fp16)
+            _, fp32_idx = torch.topk(fp32_choice_scores, k=top_k, dim=-1)
+            _, fp16_idx = torch.topk(fp16_choice_scores, k=top_k, dim=-1)
+            ordered_mismatch = (fp32_idx != fp16_idx).any(dim=-1).sum().item()
+            set_mismatch = (
+                torch.sort(fp32_idx, dim=-1).values
+                != torch.sort(fp16_idx, dim=-1).values
+            ).any(dim=-1).sum().item()
+            max_abs_logit_delta = (
+                router_logits_fp32 - router_logits_fp16
+            ).abs().max().item()
+            candidate_misses: list[tuple[int, int]] = []
+            max_candidates = router_logits_fp16.shape[-1]
+            for candidate_count in (16, 32):
+                if candidate_count > max_candidates:
+                    continue
+                _, fp16_candidates = torch.topk(
+                    fp16_choice_scores, k=candidate_count, dim=-1
+                )
+                covered = (
+                    fp32_idx.unsqueeze(-1) == fp16_candidates.unsqueeze(-2)
+                ).any(dim=-1).all(dim=-1)
+                candidate_misses.append(
+                    (candidate_count, (~covered).sum().item())
+                )
+            max_abs_choice_delta = (
+                fp32_choice_scores - fp16_choice_scores
+            ).abs().max().item()
+
+        print(
+            "[minimax-fp16-router-audit] "
+            f"layer={self.layer_name} phase={audit_key} tokens={num_tokens} "
+            f"top_k={top_k} ordered_mismatch={ordered_mismatch} "
+            f"set_mismatch={set_mismatch} "
+            f"max_abs_logit_delta={max_abs_logit_delta:.6g} "
+            f"max_abs_choice_delta={max_abs_choice_delta:.6g} "
+            + " ".join(
+                f"top{candidate_count}_candidate_miss={miss_count}"
+                for candidate_count, miss_count in candidate_misses
+            ),
+            flush=True,
+        )
