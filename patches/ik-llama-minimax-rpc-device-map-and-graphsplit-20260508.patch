+                    up = dots.up;
+                } else {
+                    gate = moe_iq4_xs_q8_1_dot(gate_row, y, ncols, item_ct1);
+                    up = moe_iq4_xs_q8_1_dot(up_row, y, ncols, item_ct1);
+                }
+
+                if (item_ct1.get_local_id(2) == 0) {
+                    float * dst_row = (float *)((char *)dst + token * dst_nb2 + id * dst_nb1);
+                    dst_row[row] = up * ggml_sycl_apply_moe_gate_unary(gate, unary_op, limit);
