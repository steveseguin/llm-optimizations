+                }
+            }
+
+            auto produced_in_wave = [&producer_split] (const ggml_tensor * tensor, int wave_start, int wave_end) {
+                const ggml_tensor * key = tensor->view_src ? tensor->view_src : tensor;
+                auto it = producer_split.find(key);
