+static void ggml_backend_rpc_split_set_merged_view(ggml_tensor * tensor, const void * data) {
+    auto view_src = tensor->view_src;
+    auto extra = (ggml_split_tensor_t *) view_src->extra;
+    void * extra_ptr = nullptr;
+    memcpy(&extra_ptr, view_src->op_params, sizeof(extra_ptr));
+    if (!extra_ptr) {
+        return;
+    }
+
+    std::string merged_name = view_src->name;
+    if (merged_name.find("ffn_gate_up_exps.weight") != std::string::npos) {
+        std::string name = tensor->name;
+        const bool is_up   = name.find("ffn_up_exps.weight")   != std::string::npos;
+        const bool is_gate = name.find("ffn_gate_exps.weight") != std::string::npos;
+        if (!is_up && !is_gate) {
+            return;
+        }
+
+        GGML_ASSERT(extra->split_dim == 1);
+        auto & ranges = *(const std::vector<std::vector<std::pair<int, int>>> *) extra_ptr;
+        int ne = 0;
+        for (int is = 0; is < (int) ranges.size(); ++is) {
+            auto & r = ranges[is];
+            GGML_ASSERT((extra->splits[is] && !r.empty()) || (!extra->splits[is] && r.empty()));
+            if (r.empty()) {
+                continue;
+            }
+
+            GGML_ASSERT(r.size() == 2);
+            ggml_tensor * split = extra->splits[is];
+            const int ir = is_gate ? 0 : 1;
+            auto p = r[ir];
+            size_t dst_offset = 0;
+            if (ir == 1) {
+                p.first -= tensor->ne[1];
+                GGML_ASSERT(p.first >= 0);
+                dst_offset = split->ne[1] / 2 * split->nb[1];
+            }
+
+            for (int64_t i02 = 0; i02 < split->ne[2]; ++i02) {
+                const size_t this_dst_offset = i02 * split->nb[2] + dst_offset;
+                const char * src = (const char *) data + i02 * tensor->nb[2] + ne * tensor->nb[1];
+                ggml_backend_tensor_set(split, src, this_dst_offset, p.second * tensor->nb[1]);
+            }
+            ne += p.second;
+        }
+        return;
+    }
+
+    if (merged_name.find("ffn_gate_up_exps.bias") != std::string::npos) {
+        std::string name = tensor->name;
+        const bool is_up   = name.find("ffn_up_exps.bias")   != std::string::npos;
+        const bool is_gate = name.find("ffn_gate_exps.bias") != std::string::npos;
+        if (!is_up && !is_gate) {
+            return;
+        }
+
+        GGML_ASSERT(extra->split_dim == 0);
+        auto & ranges = *(const std::vector<std::vector<std::pair<int, int>>> *) extra_ptr;
+        int ne = 0;
+        for (int is = 0; is < (int) ranges.size(); ++is) {
+            auto & r = ranges[is];
+            GGML_ASSERT((extra->splits[is] && !r.empty()) || (!extra->splits[is] && r.empty()));
+            if (r.empty()) {
+                continue;
+            }
+
+            GGML_ASSERT(r.size() == 2);
+            ggml_tensor * split = extra->splits[is];
+            const int ir = is_gate ? 0 : 1;
+            auto p = r[ir];
+            size_t dst_offset = 0;
+            if (ir == 1) {
+                p.first -= tensor->ne[0];
+                GGML_ASSERT(p.first >= 0);
+                dst_offset = split->ne[0] / 2 * split->nb[0];
+            }
+
+            for (int64_t i01 = 0; i01 < split->ne[1]; ++i01) {
+                const size_t this_dst_offset = i01 * split->nb[1] + dst_offset;
+                const char * src = (const char *) data + i01 * tensor->nb[1] + ne * tensor->nb[0];
+                ggml_backend_tensor_set(split, src, this_dst_offset, p.second * tensor->nb[0]);
+            }
+            ne += p.second;
+        }
+    }
+}
+
+static void ggml_backend_rpc_split_buffer_set_tensor(ggml_backend_buffer_t buffer, ggml_tensor * tensor, const void * data, size_t offset, size_t size) {
+    UNUSED(buffer);
+
+    if (!tensor->extra && tensor->view_src && tensor->view_src->extra) {
+        ggml_backend_rpc_split_set_merged_view(tensor, data);
+        return;
+    }
+
+    if (!tensor->extra) {
+        return;
+    }
+
+    // Split tensors must always be set in their entirety at once.
+    GGML_ASSERT(offset == 0);
+    GGML_ASSERT(size == ggml_nbytes(tensor));
+
+    static const std::unordered_map<ggml_type, int> k_map = {
+        { GGML_TYPE_Q4_0_R8   , 8},
+        { GGML_TYPE_Q5_0_R4   , 4},
+        { GGML_TYPE_Q8_0_R8   , 8},
+        { GGML_TYPE_Q2_K_R4   , 4},
+        { GGML_TYPE_Q3_K_R4   , 4},
+        { GGML_TYPE_Q4_K_R4   , 4},
+        { GGML_TYPE_Q5_K_R4   , 4},
+        { GGML_TYPE_Q6_K_R4   , 4},
+        { GGML_TYPE_IQ2_XXS_R4, 4},
+        { GGML_TYPE_IQ2_XS_R4 , 4},
+        { GGML_TYPE_IQ3_XXS_R4, 4},
+        { GGML_TYPE_IQ1_S_R4  , 4},
+        { GGML_TYPE_IQ4_NL_R4 , 4},
+        { GGML_TYPE_IQ3_S_R4  , 4},
+        { GGML_TYPE_IQ2_S_R4  , 4},
+        { GGML_TYPE_IQ4_XS_R8 , 8},
+        { GGML_TYPE_IQ1_M_R4  , 4},
+        { GGML_TYPE_BF16_R16  , 16},
+        { GGML_TYPE_Q6_0_R4   , 4},
+        { GGML_TYPE_IQ2_BN_R4 , 4},
+        { GGML_TYPE_IQ2_K_R4  , 4},
+        { GGML_TYPE_IQ3_K_R4  , 4},
+        { GGML_TYPE_IQ4_K_R4  , 4},
+        { GGML_TYPE_IQ5_K_R4  , 4},
+        { GGML_TYPE_IQ4_KS_R4 , 4},
+        { GGML_TYPE_IQ5_KS_R4 , 4},
+        { GGML_TYPE_Q8_K_R16  , 4},
+        { GGML_TYPE_Q8_KV_R8  , 4},
+        { GGML_TYPE_Q8_K_R8   , 8},
+    };
+
+    auto extra = (ggml_split_tensor_t *) tensor->extra;
+
+    if (extra->split_dim < 0) {
+        GGML_ASSERT(ggml_is_contiguous(tensor));
+        const size_t nbytes = ggml_nbytes(tensor);
+        for (int i = 0; i < extra->n_device; ++i) {
+            ggml_tensor * split = extra->splits[i];
+            if (!split) {
+                continue;
+            }
+            GGML_ASSERT(split->type == tensor->type);
+            GGML_ASSERT(ggml_are_same_shape(tensor, split));
+            GGML_ASSERT(ggml_nbytes(split) == nbytes);
+            ggml_backend_tensor_set(split, data, 0, nbytes);
+        }
+    } else if (extra->split_dim == 0) {
+        int n_interleave = 1;
+        if (auto it = k_map.find(tensor->type); it != k_map.end()) {
+            n_interleave = it->second;
+        }
+
+        auto tt = ggml_internal_get_type_traits(tensor->type);
+        std::vector<char> host_buffer;
+        GGML_ASSERT(ggml_is_contiguous(tensor));
+        const int nrows = ggml_nrows(tensor);
+        const auto bs = tt.blck_size;
+        const auto ts = tt.type_size;
+
+        void * extra_ptr = nullptr;
+        memcpy(&extra_ptr, tensor->op_params, sizeof(extra_ptr));
+        if (extra_ptr) {
+            auto & ranges = *(const std::vector<std::vector<std::pair<int, int>>> *) extra_ptr;
+            GGML_ASSERT(extra->n_device == (int) ranges.size());
+            GGML_ASSERT(tensor->ne[2] * tensor->ne[3] == 1);
+            GGML_ASSERT(n_interleave == 1);
+            GGML_ASSERT(tt.row_meta_size == 0);
+            for (int i = 0; i < extra->n_device; ++i) {
+                ggml_tensor * split = extra->splits[i];
+                if (!split) {
+                    GGML_ASSERT(ranges[i].empty());
+                    continue;
+                }
+                GGML_ASSERT(!ranges[i].empty());
+                GGML_ASSERT((int) ggml_nrows(split) == nrows);
+                const size_t split_row_size = ggml_row_size(split->type, split->ne[0]);
+                if (host_buffer.size() < (size_t) nrows * split_row_size) {
+                    host_buffer.resize((size_t) nrows * split_row_size);
+                }
+                char * dst = host_buffer.data();
+                for (int64_t i01 = 0; i01 < split->ne[1]; i01 += n_interleave) {
+                    for (auto & p : ranges[i]) {
+                        GGML_ASSERT(p.first  % bs == 0);
+                        GGML_ASSERT(p.second % bs == 0);
+                        const char * src = (const char *) data + i01 * tensor->nb[1] + (p.first / bs) * ts;
+                        const size_t this_size = (p.second / bs) * ts;
+                        memcpy(dst, src, this_size);
+                        dst += this_size;
+                    }
+                }
+                ggml_backend_tensor_set(split, host_buffer.data(), 0, (size_t) nrows * split_row_size);
+            }
+        } else {
+            int ne = 0;
+            for (int i = 0; i < extra->n_device; ++i) {
+                ggml_tensor * split = extra->splits[i];
+                if (!split) {
+                    continue;
+                }
+                GGML_ASSERT(split->ne[1] % n_interleave == 0);
+                GGML_ASSERT(split->type == tensor->type);
+                GGML_ASSERT((int) ggml_nrows(split) == nrows);
+                GGML_ASSERT(split->ne[0] % bs == 0);
+                const size_t source_offset = n_interleave * (tt.row_meta_size + (ne / bs) * ts);
+                const size_t split_row_size = ggml_row_size(split->type, split->ne[0]);
+                if (host_buffer.size() < (size_t) nrows * split_row_size) {
+                    host_buffer.resize((size_t) nrows * split_row_size);
+                }
+                for (int64_t i02 = 0; i02 < split->ne[2]; ++i02) {
+                    for (int64_t i01 = 0; i01 < split->ne[1]; i01 += n_interleave) {
+                        char * dst = host_buffer.data() + (i02 * split->ne[1] + i01) * split_row_size;
+                        const char * src = (const char *) data + i02 * tensor->nb[2] + i01 * tensor->nb[1];
+                        if (tt.row_meta_size > 0) {
+                            memcpy(dst, src, tt.row_meta_size * n_interleave);
+                        }
+                        memcpy(dst + tt.row_meta_size * n_interleave, src + source_offset,
+                               n_interleave * (split_row_size - tt.row_meta_size));
+                    }
+                }
+                ggml_backend_tensor_set(split, host_buffer.data(), 0, (size_t) nrows * split_row_size);
+                ne += split->ne[0];
+            }
+        }
+    } else if (extra->split_dim == 1) {
+        void * extra_ptr = nullptr;
+        memcpy(&extra_ptr, tensor->op_params, sizeof(extra_ptr));
+        if (tensor->ne[2] > 1) {
+            const size_t row_size = ggml_row_size(tensor->type, tensor->ne[0]);
+            std::vector<char> host_buffer;
+            int ne1 = 0;
+            for (int i = 0; i < extra->n_device; ++i) {
+                ggml_tensor * split = extra->splits[i];
+                if (!split) {
+                    continue;
+                }
+                const size_t split_size = ggml_nbytes(split);
+                if (host_buffer.size() < split_size) {
+                    host_buffer.resize(split_size);
+                }
+                for (int64_t i02 = 0; i02 < split->ne[2]; ++i02) {
+                    char * dst = host_buffer.data() + i02 * split->ne[1] * row_size;
+                    if (extra_ptr) {
+                        auto & ranges = *(const std::vector<std::vector<std::pair<int, int>>> *) extra_ptr;
+                        for (auto & p : ranges[i]) {
+                            const char * this_src = (const char *) data + i02 * tensor->nb[2] + p.first * tensor->nb[1];
+                            const size_t this_size = p.second * tensor->nb[1];
+                            memcpy(dst, this_src, this_size);
+                            dst += this_size;
+                        }
+                    } else {
+                        const char * src = (const char *) data + i02 * tensor->nb[2] + ne1 * tensor->nb[1];
+                        memcpy(dst, src, split->ne[1] * row_size);
+                    }
+                }
+                ggml_backend_tensor_set(split, host_buffer.data(), 0, split_size);
+                ne1 += split->ne[1];
+            }
+        } else {
+            int n_interleave = 1;
+            if (auto it = k_map.find(tensor->type); it != k_map.end()) {
+                n_interleave = it->second;
+            }
+            if (extra_ptr) {
+                auto & ranges = *(const std::vector<std::vector<std::pair<int, int>>> *) extra_ptr;
+                GGML_ASSERT(extra->n_device == (int) ranges.size());
+                GGML_ASSERT(tensor->ne[2] * tensor->ne[3] == 1);
+                GGML_ASSERT(n_interleave == 1);
+                for (int i = 0; i < extra->n_device; ++i) {
+                    ggml_tensor * split = extra->splits[i];
+                    if (!split) {
+                        GGML_ASSERT(ranges[i].empty());
+                        continue;
+                    }
+                    GGML_ASSERT(!ranges[i].empty());
+                    size_t dst_offset = 0;
+                    for (auto & p : ranges[i]) {
+                        GGML_ASSERT(p.first  >= 0 && p.first < tensor->ne[1]);
+                        GGML_ASSERT(p.second >= 0 && p.first + p.second <= tensor->ne[1]);
+                        const char * src = (const char *) data + p.first * tensor->nb[1];
+                        const size_t this_size = p.second * tensor->nb[1];
+                        ggml_backend_tensor_set(split, src, dst_offset, this_size);
+                        dst_offset += this_size;
+                    }
+                }
+            } else {
+                size_t cur_offset = 0;
+                for (int i = 0; i < extra->n_device; ++i) {
+                    ggml_tensor * split = extra->splits[i];
+                    if (!split) {
+                        continue;
+                    }
+                    GGML_ASSERT(split->ne[1] % n_interleave == 0);
+                    const size_t split_size = ggml_nbytes(split);
+                    const char * buf_host = (const char *) data + cur_offset;
+                    ggml_backend_tensor_set(split, buf_host, 0, split_size);
+                    cur_offset += split_size;
+                }
+            }
+        }
+    } else {
+        GGML_ABORT("%s: unsupported split dim %d\n", __func__, extra->split_dim);
+    }
+}
