+static __dpct_inline__ float moe_iq4_xs_q8_1_dot(const char * row, const block_q8_1 * y,
+                                                 const int ncols,
+                                                 const sycl::nd_item<3> & item_ct1) {
+    const int blocks_per_row = ncols / QK_K;
+    constexpr int qi = QI4_XS / 4;
+    constexpr int vdr = 1;
+    const int blocks_per_warp = vdr * WARP_SIZE / qi;
+
+    float tmp = 0.0f;
+    const block_iq4_xs * x = (const block_iq4_xs *) row;
+
+    for (int i = item_ct1.get_local_id(2) / (qi / vdr); i < blocks_per_row;
+         i += blocks_per_warp) {
+        const int iby = i * (QK_K / QK8_1);
+        const int iqs = vdr * (item_ct1.get_local_id(2) % (qi / vdr));
+        tmp += vec_dot_iq4_xs_q8_1(&x[i], &y[iby], iqs);
+    }
+
+#pragma unroll
+    for (int mask = WARP_SIZE / 2; mask > 0; mask >>= 1) {
+        tmp += dpct::permute_sub_group_by_xor(item_ct1.get_sub_group(), tmp, mask);
+    }
+
+    return tmp;
+}
+
+struct moe_iq4_xs_q8_1_pair {
+    float gate;
+    float up;
+};
+
+static __dpct_inline__ moe_iq4_xs_q8_1_pair moe_iq4_xs_q8_1_dot_pair(
+        const char * gate_row, const char * up_row, const block_q8_1 * y,
+        const int ncols, const sycl::nd_item<3> & item_ct1) {
+    const int blocks_per_row = ncols / QK_K;
+    constexpr int qi = QI4_XS / 4;
+    constexpr int vdr = 1;
+    const int blocks_per_warp = vdr * WARP_SIZE / qi;
+
+    float gate_tmp = 0.0f;
+    float up_tmp = 0.0f;
+    const block_iq4_xs * gate_x = (const block_iq4_xs *) gate_row;
+    const block_iq4_xs * up_x = (const block_iq4_xs *) up_row;
+
+    for (int i = item_ct1.get_local_id(2) / (qi / vdr); i < blocks_per_row;
+         i += blocks_per_warp) {
+        const int iby = i * (QK_K / QK8_1);
+        const int iqs = vdr * (item_ct1.get_local_id(2) % (qi / vdr));
+        const block_q8_1 * y_block = &y[iby];
+        gate_tmp += vec_dot_iq4_xs_q8_1(&gate_x[i], y_block, iqs);
+        up_tmp += vec_dot_iq4_xs_q8_1(&up_x[i], y_block, iqs);
+    }
+
+#pragma unroll
+    for (int mask = WARP_SIZE / 2; mask > 0; mask >>= 1) {
+        gate_tmp += dpct::permute_sub_group_by_xor(item_ct1.get_sub_group(), gate_tmp, mask);
+        up_tmp += dpct::permute_sub_group_by_xor(item_ct1.get_sub_group(), up_tmp, mask);
+    }
+
+    return {gate_tmp, up_tmp};
+}
