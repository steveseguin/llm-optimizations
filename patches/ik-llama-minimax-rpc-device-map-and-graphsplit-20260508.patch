+GGML_CALL static size_t ggml_backend_rpc_split_buffer_type_get_alloc_size(ggml_backend_buffer_type_t buft, const ggml_tensor * tensor) {
+    if (!tensor->extra) {
+        return 0;
+    }
+
+    ggml_backend_rpc_split_buffer_type_context * ctx = (ggml_backend_rpc_split_buffer_type_context *) buft->context;
+    auto extra = (ggml_split_tensor_t *) tensor->extra;
+    GGML_ASSERT(extra->n_device <= (int) ctx->servers.size());
+
+    size_t total_size = 0;
+    for (int i = 0; i < extra->n_device; ++i) {
+        ggml_tensor * split = extra->splits[i];
+        if (!split) {
+            continue;
+        }
+        const auto & server = ctx->servers[i];
+        ggml_backend_buffer_type_t split_buft = ggml_backend_rpc_buffer_type(server.endpoint.c_str(), server.device);
+        GGML_ASSERT(split_buft != nullptr);
+        total_size += ggml_backend_buft_get_alloc_size(split_buft, split);
+    }
+    return total_size;
+}
