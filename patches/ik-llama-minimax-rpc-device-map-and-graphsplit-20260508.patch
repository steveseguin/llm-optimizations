+static __dpct_inline__ float ggml_sycl_apply_moe_gate_unary(const float x, const int unary_op, const float limit) {
+    float y;
+    switch ((ggml_unary_op) unary_op) {
+        case GGML_UNARY_OP_SILU:
+            y = x / (1.0f + sycl::native::exp(-x));
+            break;
+        case GGML_UNARY_OP_GELU:
+            {
+                const float GELU_COEF_A    = 0.044715f;
+                const float SQRT_2_OVER_PI = 0.79788456080286535587989211986876f;
+                y = 0.5f * x * (1.0f + sycl::tanh(SQRT_2_OVER_PI * x * (1.0f + GELU_COEF_A * x * x)));
+            }
+            break;
+        case GGML_UNARY_OP_RELU:
+            y = sycl::fmax(0.0f, x);
+            break;
+        default:
+            y = x;
+            break;
+    }
+
+    return limit > 1e-6f ? sycl::fmin(y, limit) : y;
+}
