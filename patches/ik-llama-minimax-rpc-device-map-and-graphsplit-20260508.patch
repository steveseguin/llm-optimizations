+static void ggml_backend_rpc_split_buffer_init_tensor(ggml_backend_buffer_t buffer, ggml_tensor * tensor) {
+    if (!tensor->extra) {
+        return;
+    }
+
+    ggml_backend_rpc_split_buffer_context * ctx = (ggml_backend_rpc_split_buffer_context *) buffer->context;
+    ggml_backend_rpc_split_buffer_type_context * buft_ctx = (ggml_backend_rpc_split_buffer_type_context *) buffer->buft->context;
+    auto extra = (ggml_split_tensor_t *) tensor->extra;
+
+    GGML_ASSERT(extra->n_device <= (int) buft_ctx->servers.size());
+    for (int i = 0; i < extra->n_device; ++i) {
+        ggml_tensor * split = extra->splits[i];
+        if (!split || split->buffer) {
+            continue;
+        }
+
+        const auto & server = buft_ctx->servers[i];
+        ggml_backend_buffer_type_t split_buft = ggml_backend_rpc_buffer_type(server.endpoint.c_str(), server.device);
+        GGML_ASSERT(split_buft != nullptr);
+
+        const size_t alloc_size = ggml_backend_buft_get_alloc_size(split_buft, split);
+        if (getenv("GGML_RPC_SPLIT_DEBUG")) {
+            fprintf(stderr,
+                    "rpc_split_alloc: tensor=%s split=%s split_dim=%d rpc=%s|%u bytes=%zu\n",
+                    tensor->name, split->name, extra->split_dim,
+                    server.endpoint.c_str(), server.device, alloc_size);
+        }
+        ggml_backend_buffer_t split_buffer = ggml_backend_buft_alloc_buffer(split_buft, alloc_size);
+        GGML_ASSERT(split_buffer != nullptr);
+
+        ggml_backend_tensor_alloc(split_buffer, split, ggml_backend_buffer_get_base(split_buffer));
+        ggml_backend_buffer_set_usage(split_buffer, GGML_BACKEND_BUFFER_USAGE_WEIGHTS);
+        ctx->split_buffers.push_back(split_buffer);
+    }
+}
