+static ggml_status ggml_backend_rpc_graph_compute_reduce(ggml_tensor * dst) {
+    if (dst->op_params[3] == 1) {
+        return GGML_STATUS_SUCCESS;
+    }
+    if ((ggml_op) dst->op_params[0] != GGML_OP_ADD) {
+        fprintf(stderr, "%s: unsupported reduce op %d\n", __func__, dst->op_params[0]);
+        return GGML_STATUS_FAILED;
+    }
+    if (!ggml_is_contiguous(dst)) {
+        fprintf(stderr, "%s: non-contiguous reduce dst %s is not supported\n", __func__, dst->name);
+        return GGML_STATUS_FAILED;
+    }
+
+    const int n_src = dst->op_params[1];
+    const size_t nbytes = ggml_nbytes(dst);
+    const int64_t nelem = ggml_nelements(dst);
+    static const bool mirror_reduce = []() {
+        const char * env = getenv("GGML_RPC_REDUCE_MIRROR");
+        return env && strcmp(env, "0") != 0;
+    }();
+
+    switch (dst->type) {
+        case GGML_TYPE_F32: {
+            std::vector<float> accum(nelem, 0.0f);
+            std::vector<float> tmp(nelem);
+            for (int i = 0; i < n_src; ++i) {
+                const ggml_tensor * src = dst->src[i];
+                if (!src) {
+                    continue;
+                }
+                GGML_ASSERT(src->type == dst->type);
+                GGML_ASSERT(ggml_are_same_shape(src, dst));
+                GGML_ASSERT(ggml_is_contiguous(src));
+                ggml_backend_tensor_get(src, tmp.data(), 0, nbytes);
+            for (int64_t j = 0; j < nelem; ++j) {
+                accum[j] += tmp[j];
+            }
+        }
+            if (mirror_reduce) {
+                for (int i = 0; i < n_src; ++i) {
+                    ggml_tensor * src = dst->src[i];
+                    if (src) {
+                        ggml_backend_tensor_set(src, accum.data(), 0, nbytes);
+                    }
+                }
+            } else {
+                ggml_backend_tensor_set(dst, accum.data(), 0, nbytes);
+            }
+            return GGML_STATUS_SUCCESS;
+        }
+        case GGML_TYPE_F16: {
+            std::vector<float> accum(nelem, 0.0f);
+            std::vector<ggml_fp16_t> tmp(nelem);
+            for (int i = 0; i < n_src; ++i) {
+                const ggml_tensor * src = dst->src[i];
+                if (!src) {
+                    continue;
+                }
+                GGML_ASSERT(src->type == dst->type);
+                GGML_ASSERT(ggml_are_same_shape(src, dst));
+                GGML_ASSERT(ggml_is_contiguous(src));
+                ggml_backend_tensor_get(src, tmp.data(), 0, nbytes);
+                for (int64_t j = 0; j < nelem; ++j) {
+                    accum[j] += ggml_fp16_to_fp32(tmp[j]);
+                }
+            }
+            std::vector<ggml_fp16_t> out(nelem);
+            for (int64_t j = 0; j < nelem; ++j) {
+                out[j] = ggml_fp32_to_fp16(accum[j]);
+            }
+            if (mirror_reduce) {
+                for (int i = 0; i < n_src; ++i) {
+                    ggml_tensor * src = dst->src[i];
+                    if (src) {
+                        ggml_backend_tensor_set(src, out.data(), 0, nbytes);
+                    }
+                }
+            } else {
+                ggml_backend_tensor_set(dst, out.data(), 0, nbytes);
+            }
+            return GGML_STATUS_SUCCESS;
+        }
+        default:
+            fprintf(stderr, "%s: unsupported reduce type %s for %s\n", __func__, ggml_type_name(dst->type), dst->name);
+            return GGML_STATUS_FAILED;
+    }
+}
