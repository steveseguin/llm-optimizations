+def _allreduce_label_enabled(label: str | None) -> bool:
+    if label is None or os.environ.get("VLLM_XPU_DECODE_TIMING", "0") != "1":
+        return False
+    try:
+        compiler = getattr(torch, "compiler", None)
+        if compiler is not None and compiler.is_compiling():
+            return False
+    except Exception:
+        pass
+    return True
+
+
+def tensor_model_parallel_all_reduce(
+    input_: torch.Tensor,
+    label: str | None = None,
+) -> torch.Tensor:
     """All-reduce the input tensor across model parallel group."""
+    if _allreduce_label_enabled(label):
+        from vllm.utils.xpu_decode_timing import allreduce_label
+
+        with allreduce_label(label):
+            return get_tp_group().all_reduce(input_)
     return get_tp_group().all_reduce(input_)
 
 
